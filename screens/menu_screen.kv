#:kivy 2.3.1

<MenuScreen>:
    name: 'menu'
    canvas.before:
        Color:
            rgba: .96, .91, .84, 1
        Rectangle:
            pos: self.pos
            size: self.size


    GridLayout:
        cols: 1
        BoxLayout:

            #size_hint_y: .9
            orientation: 'vertical'

            Label:
                size_hint_y: .3
                text: 'Главная страница'

            ScrollView:
                GridLayout:
                    id: recipes_grid
                    cols: 3
                    spacing: 10
                    padding: 20

                    size_hint_y: None
                    height: self.minimum_height






